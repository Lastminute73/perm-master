<?xml version="1.0" encoding="UTF-8"?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <name>Results by Status</name>
    <description>All processing results grouped by status, then by result type. Useful for tracking what has been approved, applied, or is still pending.</description>
    <reportType>CustomEntity$Gong_Processing_Result__c</reportType>
    <format>Summary</format>
    <showDetails>true</showDetails>
    <showGrandTotal>true</showGrandTotal>
    <showSubTotals>true</showSubTotals>
    <timeFrameFilter>
        <dateColumn>CREATED_DATE</dateColumn>
        <interval>INTERVAL_LAST90</interval>
    </timeFrameFilter>
    <groupingsDown>
        <dateGranularity>Day</dateGranularity>
        <field>Gong_Processing_Result__c.Status__c</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <groupingsDown>
        <dateGranularity>Day</dateGranularity>
        <field>Gong_Processing_Result__c.Result_Type__c</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <columns>
        <field>Gong_Processing_Result__c.Email__c</field>
    </columns>
    <columns>
        <field>Gong_Processing_Result__c.First_Name__c</field>
    </columns>
    <columns>
        <field>Gong_Processing_Result__c.Last_Name__c</field>
    </columns>
    <columns>
        <field>Gong_Processing_Result__c.Domain__c</field>
    </columns>
    <columns>
        <field>Gong_Processing_Result__c.Account__c</field>
    </columns>
    <columns>
        <field>Gong_Processing_Result__c.Matched_Record_Name__c</field>
    </columns>
    <columns>
        <field>Gong_Processing_Result__c.AI_Quality_Score__c</field>
    </columns>
    <columns>
        <field>Gong_Processing_Result__c.Error_Message__c</field>
    </columns>
</Report>
